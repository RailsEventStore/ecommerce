<div class="max-w-xl mx-auto py-8 px-4">
  <h1 class="text-2xl font-bold mb-6">Latest tweets</h1>

  <% if current_handle %>
    <%= form_with url: tweets_path, method: :post, class: "mb-6" do |form| %>
      <%= form.text_area :body, placeholder: "What's happening?", class: "w-full border rounded px-3 py-2" %>
      <%= form.submit "Tweet", class: "mt-2 bg-blue-600 text-white rounded px-4 py-2" %>
    <% end %>
  <% end %>

  <% if @tweets.empty? %>
    <p class="text-gray-500">No tweets yet.</p>
  <% else %>
    <ul class="divide-y divide-gray-200">
      <% @tweets.each do |tweet| %>
        <li class="py-4">
          <span class="font-semibold">@<%= link_to tweet.author, profile_path(tweet.author), data: { tweet_author: "" }, class: "hover:underline" %></span>
          <p data-tweet-body class="mt-1 text-gray-800"><%= tweet.body %></p>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
