<div class="max-w-2xl mx-auto py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold"><%= @deal.name %></h1>
    <%= link_to "Edit", edit_deal_path(@deal.uid), class: "text-blue-600 hover:underline" %>
  </div>

  <dl class="space-y-4">
    <div>
      <dt class="text-sm text-gray-500">Pipeline</dt>
      <dd class="text-lg"><%= @pipeline.name %></dd>
    </div>
    <div>
      <dt class="text-sm text-gray-500">Value</dt>
      <dd class="text-lg"><%= @deal.value || "—" %></dd>
    </div>
    <div>
      <dt class="text-sm text-gray-500">Expected Close Date</dt>
      <dd class="text-lg"><%= @deal.expected_close_date || "—" %></dd>
    </div>
    <div>
      <dt class="text-sm text-gray-500">Stage</dt>
      <dd class="text-lg"><%= @deal.stage || "—" %></dd>
    </div>
    <div>
      <dt class="text-sm text-gray-500">Companies</dt>
      <dd class="text-lg">
        <% if @companies.any? %>
          <% @companies.each do |dc| %>
            <span><%= Companies.find_by_uid(dc.company_uid).name %></span>
          <% end %>
        <% else %>
          —
        <% end %>
      </dd>
    </div>
    <div>
      <dt class="text-sm text-gray-500">Contacts</dt>
      <dd class="text-lg">
        <% if @contacts.any? %>
          <% @contacts.each do |dc| %>
            <span><%= Contacts.find_by_uid(dc.contact_uid).name %></span>
          <% end %>
        <% else %>
          —
        <% end %>
      </dd>
    </div>
  </dl>

  <div class="mt-8">
    <%= link_to "Back to Deals", deals_path, class: "text-gray-600 hover:underline" %>
  </div>
</div>
