<div class="max-w-2xl mx-auto py-8">
  <h1 class="text-2xl font-bold mb-6">New Deal</h1>

  <%= form_with url: deals_path, scope: :deal, method: :post, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :pipeline_id, "Pipeline", class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :pipeline_id, @pipelines, :uid, :name, { prompt: "Select a pipeline" }, class: "mt-1 block w-full rounded border-gray-300 shadow-sm" %>
    </div>
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, required: true, class: "mt-1 block w-full rounded border-gray-300 shadow-sm" %>
    </div>
    <div>
      <%= f.label :value, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :value, class: "mt-1 block w-full rounded border-gray-300 shadow-sm" %>
    </div>
    <div>
      <%= f.label :expected_close_date, "Expected Close Date", class: "block text-sm font-medium text-gray-700" %>
      <%= f.date_field :expected_close_date, class: "mt-1 block w-full rounded border-gray-300 shadow-sm" %>
    </div>
    <div>
      <%= f.submit "Create Deal", class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
